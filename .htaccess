<IfModule mod_headers.c>
  # ─────────────────────────────────────────────────────────────────────────────
  # Phase 2 & 3: Content Security Policy
  # ─────────────────────────────────────────────────────────────────────────────
  Header set Content-Security-Policy "script-src 'self' 'unsafe-inline' https://apis.google.com https://accounts.google.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://www.googleapis.com https://accounts.google.com https://gmail.googleapis.com https://etccapps.com https://www.google-analytics.com https://analytics.google.com https://api.github.com; frame-src 'self' https://content-gmail.googleapis.com https://accounts.google.com; default-src 'self';"

  # ─────────────────────────────────────────────────────────────────────────────
  # Phase 3: Missing Security Headers (NIST 800-53 compliance)
  # ─────────────────────────────────────────────────────────────────────────────

  # X-Content-Type-Options: Prevent MIME type sniffing attacks
  Header set X-Content-Type-Options "nosniff"

  # X-Frame-Options: Prevent clickjacking (allow same-origin only)
  Header set X-Frame-Options "SAMEORIGIN"

  # Referrer-Policy: Prevent referrer leakage
  Header set Referrer-Policy "no-referrer"

  # Permissions-Policy: Restrict access to sensitive browser features
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

  # Strict-Transport-Security: Enforce HTTPS (1 year)
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # X-XSS-Protection: Enable browser XSS protection (legacy, but good practice)
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ─────────────────────────────────────────────────────────────────────────────
# Protect .env (DB credentials, keys) — do not rely on host defaults for this
# ─────────────────────────────────────────────────────────────────────────────
<FilesMatch "^\.env">
  Require all denied
</FilesMatch>

# ─────────────────────────────────────────────────────────────────────────────
# Phase 2: Protect Debug Log
# ─────────────────────────────────────────────────────────────────────────────
<FilesMatch "^debug_log">
  Require all denied
</FilesMatch>

# ─────────────────────────────────────────────────────────────────────────────
# Protect Backups Directory
# ─────────────────────────────────────────────────────────────────────────────
<DirectoryMatch "^/.*backups">
  Require all denied
</DirectoryMatch>

# ─────────────────────────────────────────────────────────────────────────────
# Phase 3: Protect all PHP helper files
# ─────────────────────────────────────────────────────────────────────────────
<FilesMatch "security-helpers\.php$|phase3-helpers\.php$|run-migrations\.php$">
  Require all denied
</FilesMatch>

# ─────────────────────────────────────────────────────────────────────────────
# Phase 2: Prevent directory listing
# ─────────────────────────────────────────────────────────────────────────────
Options -Indexes
